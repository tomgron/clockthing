{
  "name": "clock-screensaver",
  "version": "1.0.0",
  "description": "Elegant Analog Clock Screensaver",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:windowed": "electron . --windowed",
    "settings": "electron . /c",
    "check": "node --check main.js && node --check preload.js && node --check renderer.js",
    "build": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  },
  "build": {
    "appId": "com.clockthing.screensaver",
    "productName": "Clock Screensaver",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "style_theme.css"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "${productName}.scr"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": null,
      "uninstallerIcon": null,
      "installerHeaderIcon": null,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "include": "build/installer.nsh",
      "artifactName": "${productName} Setup.${ext}"
    }
  }
}
